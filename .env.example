# Server configuration
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-app.onrender.com


# Database configuration
MONGO_URI=mongodb://your_username:your_password@your_cluster.mongodb.net/your_db

# Authentication
JWT_SECRET=supersecretjwtkeychangeinproduction
JWT_REFRESH_SECRET=supersecretrefreshjwtkeychangeinproduction

# AI Services
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-3.5-turbo
GEMINI_API_KEY=your_gemini_api_key

# Cache & Job Queue (Optional, defaults to in-memory fallback if disabled)
REDIS_URL=redis://localhost:6379

# Storage
UPLOAD_PATH=uploads
MAX_UPLOAD_SIZE=52428800 # 50MB in bytes

# GitHub Integration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_SECRET=your_github_secret
